# ============================================================
# OpenClaw Journalist Agent - .gitignore
# ============================================================

# --- Secrets & Environment ---
.env
.envrc
*.pem
*.key
*.p12

# --- Python ---
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
*.egg
.eggs/
dist/
build/
wheels/
*.whl
pip-log.txt
.Python
MANIFEST

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Artifacts (generated at runtime) ---
artifacts/

# --- Runtime Data (stored per JOURNALIST_DATA_DIR) ---
reports/
data/

# --- Log folder (tracked via .gitkeep, contents ignored) ---
log/*
!log/.gitkeep

# --- OpenClaw workspace state (local only) ---
.openclaw/

# --- Agent memory (private, not for git) ---
memory/

# --- Agent runtime (created by handoff steps, not for git) ---
inbox/

# --- Test / Coverage ---
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
coverage.xml

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- macOS ---
.DS_Store
._*

# --- Docker (local overrides only) ---
docker-compose.override.yml

# --- Poetry (lock file is committed, but not the venv) ---
tools/.venv/

# --- Misc ---
*.tmp
*.bak
.mypy_cache/
.ruff_cache/
.pytype/
.cursorignore
.cursorindexingignore
