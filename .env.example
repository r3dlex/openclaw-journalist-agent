# ============================================================
# OpenClaw Journalist Agent - Environment Variables
# Copy to .env and fill in actual values: cp .env.example .env
# ============================================================

# --- Agent Identity ---
AGENT_NAME=Journalist
AGENT_DESCRIPTION="Research and intelligence briefing agent"

# --- User Profile (used by SOUL.md - keep out of git) ---
USER_DISPLAY_NAME="Your Name"
USER_LOCATION="City, Country"
USER_TIMEZONE="Europe/Berlin"
USER_ORIGIN_COUNTRY="Country"
USER_INTERESTS="AI/Tech, Geopolitics, Economics"

# --- Paths ---
# Where the agent stores logs, reports, and runtime data
JOURNALIST_DATA_DIR=/path/to/agent/data
# Workspace root (defaults to this repo directory)
JOURNALIST_WORKSPACE_DIR=.

# --- Inter-Agent Collaboration ---
# Path to the librarian agent workspace for handoff
LIBRARIAN_AGENT_WORKSPACE=/path/to/openclaw-librarian-agent

# --- News & Research ---
# Optional: NewsAPI key for headlines aggregation
NEWS_API_KEY=your_news_api_key_here
# RSS feed configuration file (JSON)
FEEDS_FILE=config/feeds.json

# --- Weather ---
WEATHER_LOCATION=Stuttgart
WEATHER_COUNTRY=DE

# --- Telegram Notifications ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID where briefings are delivered (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Inter-Agent Message Queue (IAMQ) ---
# HTTP URL for the OpenClaw IAMQ service (Elixir/OTP)
IAMQ_HTTP_URL=http://127.0.0.1:18790

# --- Delivery ---
# Channel for delivering briefings (telegram, whatsapp, discord)
DEFAULT_CHANNEL=telegram

# --- Headless Browser Engine ---
# Used by the Elixir-based research engine
BROWSER_ENGINE_PORT=4000
BROWSER_ENGINE_HOST=localhost

# --- Model Configuration ---
# Model used by the openclaw agent
AGENT_MODEL=claude-sonnet-4-20250514

# --- Docker ---
# Container registry prefix (optional)
CONTAINER_REGISTRY=ghcr.io/your-org
